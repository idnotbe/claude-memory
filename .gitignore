# Virtual environment
.venv/

# Python cache
__pycache__/
*.pyc

# Test artifacts
.pytest_cache/
.coverage
/test_*.py
/test_*.sh
/hook_test*.py

# IDE
.vscode/
.idea/
*.swp
*.swo
.mcp.json

# Environment
.env
.env.*

# Temp working files (analysis/verification artifacts)
temp/*
!temp/.gitkeep

# Windows reserved filename artifact
nul

# Runtime state files (generated by hooks at runtime)
.claude/.stop_hook_active
.claude/worktrees/

# Memory index is a derived artifact (rebuilt on demand from JSON source files)
.claude/memory/index.md
